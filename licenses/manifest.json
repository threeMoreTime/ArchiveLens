{
  "_comment": "ArchiveLens 零成本许可证技术清单。它记录工程证据，不构成法律意见。",
  "schema_version": 2,
  "project": {
    "name": "ArchiveLens",
    "license": "MIT",
    "license_file": "LICENSE",
    "distribution": "bundled"
  },
  "bundled": {
    "pypdfium2": {
      "version": "5.11.0",
      "license": "BSD-3-Clause",
      "source": "https://github.com/pypdfium2-team/pypdfium2",
      "distribution": "bundled-in-engine",
      "role": "PDF 渲染"
    },
    "rapidocr-onnxruntime": {
      "version": "1.4.4",
      "code_license": "Apache-2.0",
      "source": "https://github.com/RapidAI/RapidOCR/tree/v1.4.4",
      "distribution": "bundled-in-engine",
      "role": "主 OCR 识别",
      "model_copyright_owner": "Baidu",
      "model_files": [
        "ch_PP-OCRv4_det_infer.onnx",
        "PP-OCRv6_rec_small.onnx",
        "ch_ppocr_mobile_v2.0_cls_infer.onnx"
      ],
      "recognition_model": {
        "id": "PP-OCRv6-small",
        "conversion_release": "RapidOCR-3.9.1",
        "sha256": "6f327246b50388f3c176ae304bd95767ea6dc0c9ae92153ef8cbe210b3c14884",
        "charset_size": 18680
      },
      "public_redistribution_review": "required"
    },
    "onnxruntime": {
      "version": "1.24.4",
      "license": "MIT",
      "source": "https://github.com/microsoft/onnxruntime",
      "distribution": "bundled-in-engine",
      "license_material": [
        "onnxruntime/LICENSE",
        "onnxruntime/ThirdPartyNotices.txt"
      ]
    },
    "OpenCC": {
      "version": "1.2.0",
      "license": "Apache-2.0",
      "source": "https://github.com/BYVoid/OpenCC",
      "distribution": "bundled-in-engine",
      "role": "简繁字形族、台湾和香港字形索引与同模型字形复核"
    },
    "Pillow": {
      "version": "12.1.1",
      "license": "HPND-like (CMU License)",
      "source": "https://github.com/python-pillow/Pillow",
      "distribution": "bundled-in-engine"
    },
    "pytesseract": {
      "version": "0.3.13",
      "license": "Apache-2.0",
      "source": "https://github.com/madmaze/pytesseract",
      "distribution": "bundled-in-engine"
    },
    "tesseract": {
      "version": "5.5.0.20241111",
      "license": "Apache-2.0",
      "source": "https://github.com/tesseract-ocr/tesseract",
      "distribution": "bundled-native",
      "lock": "scripts/native-dependencies.lock.json"
    },
    "tessdata_fast": {
      "version": "87416418657359cb625c412a48b6e1d6d41c29bd",
      "license": "Apache-2.0",
      "source": "https://github.com/tesseract-ocr/tessdata_fast",
      "distribution": "bundled-native",
      "lock": "scripts/native-dependencies.lock.json"
    },
    "djvulibre": {
      "version": "3.5.29+4.12",
      "license": "GPL-2.0-only",
      "source": "https://sourceforge.net/projects/djvu/files/DjVuLibre/",
      "binary_source": "https://sourceforge.net/projects/djvu/files/DjVuLibre_Windows/3.5.29%2B4.12/",
      "distribution": "bundled",
      "process_boundary": "independent-command-line-process",
      "corresponding_source": "djvulibre-3.5.29.tar.gz",
      "lock": "scripts/native-dependencies.lock.json",
      "public_redistribution_review": "required"
    }
  },
  "removed": {
    "PyMuPDF": {
      "license": "AGPL-3.0-or-later or commercial",
      "distribution": "removed",
      "reason": "PDF 渲染已迁移到 pypdfium2；test_no_pymupdf 阻止回归。"
    }
  },
  "public_release_gate": {
    "technical_script": "scripts/verify-license-compliance.py",
    "approval_record": "docs/compliance/public-release-license-approval.json",
    "default": "blocked",
    "formal_release_authorization": "separate and still required"
  }
}
