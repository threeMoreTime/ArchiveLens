    },
    "djvulibre": {
      "license": "GPL-2.0",
      "source": "https://djvu.sourceforge.net/",
      "distribution": "optional-external",
      "strategy": "默认不随包；检测到外部安装后 DJVU 可用；PDF 不受影响（任务 §4.3）"
    }
  },
  "removed": {
